<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Produtos</title>
</head>
<body>
    <h1>Seus produtos aqui...</h1>
    <hr>
    <!-- exibindo uma variavel Javascrip dentro do html-->
    <!--Comentario no EJS <%# %> -->  

    <!-- Percorrendo um vetor atraves dp foreach-->
         <% listaProdutos.forEach(function(produto){ %>
            <p>
                <a href="/produtos/<%=produto%>">
                    
                 <%=produto %>
                 </a>
                </p>
                <%}) %>

         

   <p><a href= "/">Voltar para tela inicial...></a></p>
    
</body>
</html>