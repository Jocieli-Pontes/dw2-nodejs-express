<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Serviços></title>
</head>
<body>
    <h1> Bem vindo aos seus serviços!</h1>
    <hr>

    <!--Exibindo o array de objetos em uma tabela com ForEch-->
    <table border="1">
        <tr>
            <th>Serviços</th>
            <th>Descrição</th>
            <th>Preços</th>

        </tr>
    

    <% servicos.forEach(function(servico){%>
        <tr>
            <td><%= servico.servico %></td>
            <td><%= servico.descricao %></td>
            <td><%= servico.preco %></td>
        </tr>
  <% })%>
</table>
    <a href="/">Voltar para pagina inicial</a>
    
    

</html>